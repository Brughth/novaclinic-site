---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Constat from '../components/Constat.astro';
import Declic from '../components/Declic.astro';
import Pourquoi from '../components/Pourquoi.astro';
import Pillars from '../components/Pillars.astro';
import Conditions from '../components/Conditions.astro';
import Parcours from '../components/Parcours.astro';
import Comparatif from '../components/Comparatif.astro';
import Lieu from '../components/Lieu.astro';
import Programmes from '../components/Programmes.astro';
import Founding from '../components/Founding.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout canonicalPath="/">
  <Nav />
  <main id="main-content">
    <Hero />
    <Constat />
    <Declic />
    <Pourquoi />
    <Pillars />
    <Conditions />
    <Parcours />
    <Comparatif />
    <Lieu />
    <Programmes />
    <Founding />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
