---
/**
 * Layout principal — Novacare
 *
 * Inclut :
 * - Métadonnées SEO complètes (title, description, keywords)
 * - Open Graph & Twitter Cards
 * - Schema.org JSON-LD (MedicalBusiness)
 * - Hreflang FR/EN/x-default
 * - Préchargement des fonts Google
 * - Favicon + manifest PWA
 * - Skip-link accessibilité
 * - Indicateur js-enabled (fallback gracieux)
 */

import "../styles/global.css";
import { getLangFromUrl, getLocalizedUrl, type Lang } from "../i18n/config";
import { t } from "../i18n/ui";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalPath?: string;
}

const {
  title,
  description,
  ogImage = "/og-image.png",
  canonicalPath = "/",
} = Astro.props;

const lang: Lang = getLangFromUrl(Astro.url);
const i18n = t(lang);

const pageTitle = title ?? i18n.meta.title;
const pageDescription = description ?? i18n.meta.description;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const canonicalUrl = `${siteUrl}${getLocalizedUrl(canonicalPath, lang)}`;
const ogImageUrl = ogImage.startsWith("http")
  ? ogImage
  : `${siteUrl}${ogImage}`;

const frUrl = `${siteUrl}${getLocalizedUrl(canonicalPath, "fr")}`;
const enUrl = `${siteUrl}${getLocalizedUrl(canonicalPath, "en")}`;

// Schema.org JSON-LD — Centre médical (MedicalBusiness enrichi)
const jsonLdMedical = {
  "@context": "https://schema.org",
  "@type": ["MedicalBusiness", "MedicalClinic", "HealthCare"],
  "@id": `${siteUrl}/#novacare`,
  name: "Novacare",
  alternateName: [
    "Centre Novacare Malley",
    "Novacare Lausanne",
    "Novacare Malley",
    "SylvanaCare",
    "SylvanaCare Lausanne",
    "SylvanaCare Malley",
    "Novacare technology",
  ],
  description: pageDescription,
  url: siteUrl,
  image: ogImageUrl,
  logo: `${siteUrl}/og-image.png`,
  email: "adner.neyret@gmail.com",
  telephone: "+33784683417",
  medicalSpecialty: [
    "FunctionalMedicine",
    "WomensHealth",
    "Endocrinology",
    "HormonalHealth",
    "DigestiveHealth",
    "FatigueChronic",
    "Burnout",
    "IntegrativeMedicine",
    "Menopause",
    "Perimenopause",
    "ChronicFatigue",
    "HormonalDisorders",
    "IntegrativeMedicine",
    "GeneralPractice",
    "InternalMedicine",
    "GeneralSurgery",
    "Gynecology",
    "Obstetrics",
    "Ophthalmology",
    "Pediatrics",
    "Podiatry",
    "Podiatry",
    "Psychiatry",
    "Psychology",
    "Radiology",
    "Rehabilitation",
    "Dermatology",
    "Urology",
    "VascularSurgery",
    "Neurology",
    "Urology",
    "VascularSurgery",
    "Neurology",
  ],
  priceRange: "$$$",
  currenciesAccepted: "CHF",
  paymentAccepted: "Cash, Credit Card",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Complexe Malley, 7ème étage",
    addressLocality: "Lausanne",
    postalCode: "1007",
    addressRegion: "VD",
    addressCountry: "CH",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 46.5286,
    longitude: 6.6049,
  },
  areaServed: [
    { "@type": "City", name: "Lausanne" },
    { "@type": "State", name: "Vaud" },
    { "@type": "Country", name: "Switzerland" },
  ],
  audience: {
    "@type": "PeopleAudience",
    audienceType: "Women's health 35–60",
    suggestedMinAge: 30,
    suggestedMaxAge: 70,
    suggestedGender: "Female",
  },
  founder: {
    "@type": "Person",
    name: "Dr Adner Neyret",
    jobTitle: "Médecin fondateur",
    url: siteUrl,
  },
  foundingDate: "2026-09",
  openingDate: "2026-09",
  sameAs: [],
  knowsAbout: [
    "Médecine fonctionnelle",
    "Santé féminine",
    "Ménopause",
    "Périménopause",
    "Fatigue chronique",
    "Burn-out",
    "Troubles hormonaux",
    "Médecine intégrative",
    "SII",
    "Dysbiose intestinale",
    "Médecine de la femme",
    "Santé digestive",
    "Santé hormonale",
    "Santé féminine",
    "Santé intime",
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Programmes Novacare",
    itemListElement: i18n.programmes.cards.map((card) => ({
      "@type": "Offer",
      name: card.name,
      price: card.price,
      priceCurrency: "CHF",
      description: card.engagement,
    })),
  },
};

// Schema.org — WebSite (active le sitelinks search box Google)
const jsonLdWebsite = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  name: "Novacare",
  alternateName: "Centre Novacare Malley",
  url: siteUrl,
  inLanguage: [
    { "@type": "Language", name: "French", alternateName: "fr" },
    { "@type": "Language", name: "English", alternateName: "en" },
  ],
  publisher: { "@id": `${siteUrl}/#novacare` },
};

// Schema.org — Organization
const jsonLdOrg = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${siteUrl}/#organization`,
  name: "NovaCare Technology SA",
  legalName: "NovaCare Technology SA",
  url: siteUrl,
  logo: `${siteUrl}/og-image.png`,
  email: "adner.neyret@gmail.com",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Prilly",
    addressRegion: "VD",
    addressCountry: "CH",
  },
  founder: {
    "@type": "Person",
    name: "Dr Adner Neyret",
  },
};

// Schema.org — BreadcrumbList
const jsonLdBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Accueil",
      item: siteUrl,
    },
    ...(lang === "en"
      ? [
          {
            "@type": "ListItem",
            position: 2,
            name: "English",
            item: `${siteUrl}/en/`,
          },
        ]
      : []),
  ],
};

// Schema.org — FAQPage (questions des 3 piliers → rich snippets Google)
const faqItems = i18n.pillars.items.flatMap((pillar) =>
  pillar.questions.map((q) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: {
      "@type": "Answer",
      text:
        lang === "fr"
          ? `Chez Novacare, nous abordons cette question dans notre pilier ${pillar.title}. ${pillar.text} Prenez rendez-vous pour une consultation découverte de 90 minutes à Lausanne.`
          : `At Novacare, we address this through our ${pillar.title} pillar. ${pillar.text} Book a 90-minute discovery consultation in Lausanne.`,
    },
  })),
);

const jsonLdFaq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={i18n.meta.keywords} />
    <meta name="author" content="Novacare" />

    <!-- Robots — indexation agressive -->
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index, follow, max-image-preview:large, max-snippet:-1"
    />
    <meta name="bingbot" content="index, follow" />

    <!-- Google Search Console verification (remplacer par votre code) -->
    <meta
      name="google-site-verification"
      content="VOTRE_CODE_GOOGLE_SEARCH_CONSOLE"
    />
    <!-- Bing Webmaster Tools verification (remplacer par votre code) -->
    <meta name="msvalidate.01" content="VOTRE_CODE_BING_WEBMASTER" />

    <!-- Geo-targeting local — Lausanne, Suisse -->
    <meta name="geo.region" content="CH-VD" />
    <meta name="geo.placename" content="Lausanne" />
    <meta name="geo.position" content="46.5286;6.6049" />
    <meta name="ICBM" content="46.5286, 6.6049" />

    <!-- Content language -->
    <meta
      http-equiv="content-language"
      content={lang === "fr" ? "fr-CH" : "en"}
    />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang FR/EN/x-default -->
    <link rel="alternate" hreflang="fr" href={frUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={frUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === "fr" ? "fr_CH" : "en_US"} />
    <meta
      property="og:locale:alternate"
      content={lang === "fr" ? "en_US" : "fr_CH"}
    />
    <meta property="og:title" content={i18n.meta.ogTitle} />
    <meta property="og:description" content={i18n.meta.ogDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Novacare" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={i18n.meta.ogTitle} />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={i18n.meta.ogTitle} />
    <meta name="twitter:description" content={i18n.meta.ogDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={i18n.meta.ogTitle} />

    <!-- Theme color -->
    <meta name="theme-color" content="#6D2E46" />
    <meta name="msapplication-TileColor" content="#6D2E46" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Novacare" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Préchargement Google Fonts (DNS prefetch + preconnect + stylesheet) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Infant:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Cardo:ital,wght@0,400;1,400&family=Caveat:wght@400;500&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Infant:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Cardo:ital,wght@0,400;1,400&family=Caveat:wght@400;500&display=swap"
    />

    <!-- JSON-LD Structured Data (5 schemas pour rich snippets agressifs) -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLdMedical)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLdWebsite)}
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdOrg)} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLdBreadcrumb)}
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

    <meta name="generator" content={Astro.generator} />

    <slot name="head" />

    <!-- Indicateur "JS actif" — active les animations reveal -->
    <script is:inline>
      document.documentElement.classList.add("js-enabled");
    </script>
  </head>

  <body>
    <a href="#main-content" class="skip-link">{i18n.a11y.skipToContent}</a>

    <slot />

    <!-- Script global : reveal au scroll + nav scrolled state + smooth anchor scroll -->
    <script>
      // ===== Reveal animations (IntersectionObserver) =====
      const initReveal = () => {
        const elements = document.querySelectorAll<HTMLElement>(".reveal");

        if (!("IntersectionObserver" in window)) {
          elements.forEach((el) => el.classList.add("visible"));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: "0px 0px -80px 0px" },
        );

        elements.forEach((el) => observer.observe(el));
      };

      // ===== Smooth scroll pour les ancres (correction du scroll-padding) =====
      const initSmoothScroll = () => {
        document
          .querySelectorAll<HTMLAnchorElement>('a[href^="#"]')
          .forEach((anchor) => {
            anchor.addEventListener("click", function (e) {
              const href = this.getAttribute("href");
              if (!href || href === "#") return;
              const target = document.querySelector(href);
              if (target) {
                e.preventDefault();
                target.scrollIntoView({ behavior: "smooth", block: "start" });
                // Fermer un éventuel menu mobile ouvert
                document.dispatchEvent(new CustomEvent("nav:close"));
              }
            });
          });
      };

      const init = () => {
        initReveal();
        initSmoothScroll();
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init);
      } else {
        init();
      }
    </script>
  </body>
</html>
