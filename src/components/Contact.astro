---
/**
 * Section Final CTA — Formulaire de liste d'attente Founding Members
 *
 * Champs :
 *  - firstname (texte, requis)
 *  - lastname (texte, requis)
 *  - email (email, requis)
 *  - canton (select, facultatif)
 *  - symptoms (checkboxes multi-select, facultatif)
 *
 * Comportement :
 *  - Validation au submit (champs requis + email valide)
 *  - POST { firstname, lastname, email, canton, symptoms[], lang } vers l'endpoint
 *  - Si OK -> widget de succès éditorial avec prénom personnalisé + signature Adner
 *  - Sinon -> message d'erreur sous le formulaire
 */

import { getLangFromUrl, type Lang } from "../i18n/config";
import { t } from "../i18n/ui";

const lang: Lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
const c = i18n.contact;
---

<section class="final-cta" id="contact" aria-labelledby="contact-title">
  <div class="final-cta-content reveal">
    <!-- ===== ÉTAT INITIAL : titre + texte + formulaire ===== -->
    <div class="final-cta-initial" id="ctaInitial">
      <h2 id="contact-title">
        {c.titleLine1}<em>{c.titleEm}</em><br />
        {c.titleLine2}
      </h2>
      <p class="final-cta-text">{c.text}</p>

      <form
        class="inscription-form"
        id="contactForm"
        data-lang={lang}
        novalidate
      >
        <!-- Prénom + Nom sur la même ligne -->
        <div class="form-row">
          <div class="form-group">
            <label for="firstname" class="form-label"
              >{c.fields.firstname.label}</label
            >
            <input
              type="text"
              id="firstname"
              name="firstname"
              class="form-input"
              placeholder={c.fields.firstname.placeholder}
              required
              autocomplete="given-name"
              aria-describedby="firstnameError"
            />
            <div class="input-error" id="firstnameError" role="alert">
              {c.fields.firstname.error}
            </div>
          </div>

          <div class="form-group">
            <label for="lastname" class="form-label"
              >{c.fields.lastname.label}</label
            >
            <input
              type="text"
              id="lastname"
              name="lastname"
              class="form-input"
              placeholder={c.fields.lastname.placeholder}
              required
              autocomplete="family-name"
              aria-describedby="lastnameError"
            />
            <div class="input-error" id="lastnameError" role="alert">
              {c.fields.lastname.error}
            </div>
          </div>
        </div>

        <!-- Email pleine largeur -->
        <div class="form-group">
          <label for="email" class="form-label">{c.fields.email.label}</label>
          <input
            type="email"
            id="email"
            name="email"
            class="form-input"
            placeholder={c.fields.email.placeholder}
            required
            autocomplete="email"
            aria-describedby="emailError"
          />
          <div class="input-error" id="emailError" role="alert">
            {c.fields.email.error}
          </div>
        </div>

        <!-- Canton (facultatif) -->
        <div class="form-group">
          <label for="canton" class="form-label">
            {c.fields.canton.label}
            <span class="optional">{c.fields.canton.optional}</span>
          </label>
          <select id="canton" name="canton" class="form-select">
            <option value="">{c.fields.canton.placeholder}</option>
            {
              c.fields.canton.options.map((opt) => (
                <option value={opt.value}>{opt.label}</option>
              ))
            }
          </select>
        </div>

        <!-- Symptômes (facultatif, multi-select) -->
        <fieldset class="form-group symptoms-group">
          <legend class="form-label">
            {c.fields.symptoms.label}
            <span class="optional">{c.fields.symptoms.optional}</span>
          </legend>
          <p class="checkbox-help">{c.fields.symptoms.help}</p>
          <div class="checkbox-grid">
            {
              c.fields.symptoms.options.map((opt) => (
                <div class="checkbox-item">
                  <input
                    type="checkbox"
                    id={`sym-${opt.value}`}
                    name="symptoms"
                    value={opt.value}
                  />
                  <label for={`sym-${opt.value}`}>{opt.label}</label>
                </div>
              ))
            }
          </div>
        </fieldset>

        <button type="submit" class="submit-btn" id="submitBtn">
          <span class="btn-label">{c.submit}</span>
          <span class="btn-loading" aria-hidden="true">
            <span class="spinner"></span>
            {c.submitting}
          </span>
        </button>

        <!-- Message d'erreur global (réseau, serveur) -->
        <div
          id="formMessage"
          class="form-message"
          role="status"
          aria-live="polite"
          aria-atomic="true"
          data-error={c.error}
        >
        </div>

        <p class="form-note">{c.note}</p>
      </form>
    </div>

    <!-- ===== WIDGET DE SUCCÈS ===== -->
    <div
      class="success-card"
      id="successCard"
      role="status"
      aria-live="polite"
      hidden
    >
      <div class="success-icon" aria-hidden="true">
        <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
          <circle
            class="success-icon-circle"
            cx="28"
            cy="28"
            r="26"
            stroke="currentColor"
            stroke-width="1.5"
            fill="none"></circle>
          <path
            class="success-icon-check"
            d="M17 28.5L24.5 36L39 21"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"></path>
        </svg>
      </div>

      <div class="success-eyebrow">{c.success.eyebrow}</div>
      <h3 class="success-title" id="successTitle">
        <span id="successTitlePrefix"></span><em>{c.success.titleEm}</em>
      </h3>
      <p class="success-intro">
        {c.success.intro}
        <strong id="successEmail" class="success-email"></strong>
      </p>

      <div class="success-divider" aria-hidden="true">
        <span></span>
      </div>

      <div class="success-steps">
        <div class="success-steps-title">{c.success.stepsTitle}</div>
        <ol>
          {
            c.success.steps.map((step, idx) => (
              <li>
                <span class="step-num">{String(idx + 1).padStart(2, "0")}</span>
                <div class="step-body">
                  <span class="step-label">{step.label}</span>
                  <span class="step-text">{step.text}</span>
                </div>
              </li>
            ))
          }
        </ol>
      </div>

      <!-- Signature personnelle Adner -->
      <div class="success-signature">
        <div class="sig-name">{c.success.signatureName}</div>
        <div class="sig-role">{c.success.signatureRole}</div>
      </div>

      <a href="#top" class="success-back" id="successBack">
        {c.success.backLink} →
      </a>
    </div>
  </div>
</section>

<style>
  /* ============================================================
     SECTION FINAL CTA
     ============================================================ */
  .final-cta {
    padding: 11rem 3.5rem 9rem;
    background: var(--cream-paper);
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .final-cta-content {
    max-width: 640px;
    margin: 0 auto;
  }

  .final-cta-initial.hidden {
    display: none;
  }

  .final-cta h2 {
    font-family: "Cormorant Infant", serif;
    font-size: clamp(2.3rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--ink);
    font-style: italic;
    margin-bottom: 2rem;
    text-wrap: balance;
  }

  .final-cta h2 em {
    color: var(--berry);
  }

  .final-cta-text {
    font-size: 1.15rem;
    line-height: 1.75;
    color: var(--ink-soft);
    margin: 0 auto 3.5rem;
    max-width: 560px;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ============================================================
     FORMULAIRE
     ============================================================ */
  .inscription-form {
    text-align: left;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }

  .form-group {
    margin-bottom: 1.2rem;
    /* Reset pour les fieldset */
    border: none;
    padding: 0;
    min-width: 0;
  }

  .form-label {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--berry);
    font-weight: 500;
    margin-bottom: 0.6rem;
  }

  .form-label .optional {
    font-size: 0.7rem;
    color: var(--gray-mid);
    letter-spacing: 0.05em;
    text-transform: lowercase;
    font-style: italic;
    margin-left: 0.5rem;
  }

  .form-input,
  .form-select {
    width: 100%;
    padding: 0.95rem 1.3rem;
    border: 1px solid var(--gray-line);
    background: var(--white);
    font-family: "Cardo", serif;
    font-size: 1rem;
    border-radius: 100px;
    color: var(--ink);
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .form-input:focus,
  .form-select:focus {
    outline: none;
    border-color: var(--berry);
    box-shadow: 0 4px 20px rgba(109, 46, 70, 0.1);
  }

  .form-input::placeholder {
    color: var(--gray-mid);
    font-style: italic;
  }

  .form-select {
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%236D2E46' stroke-width='2'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 1.3rem center;
    background-size: 16px;
    padding-right: 3rem;
    cursor: pointer;
  }

  /* Erreur sur input/select */
  .form-input[aria-invalid="true"],
  .form-select[aria-invalid="true"] {
    border-color: #b91c1c;
  }

  /* Message d'erreur sous chaque champ */
  .input-error {
    display: none;
    font-size: 0.82rem;
    color: #b91c1c;
    margin-top: 0.5rem;
    font-style: italic;
    padding-left: 1.3rem;
  }

  .input-error.visible {
    display: block;
  }

  /* Aide texte sous le label symptômes */
  .checkbox-help {
    font-size: 0.82rem;
    color: var(--gray-mid);
    font-style: italic;
    margin: 0 0 1rem;
    padding-left: 1.3rem;
  }

  /* ============================================================
     CHECKBOXES "PILLS" (symptômes)
     ============================================================ */
  .symptoms-group {
    margin-top: 2rem;
  }

  .checkbox-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0.6rem;
  }

  .checkbox-item {
    position: relative;
    cursor: pointer;
  }

  .checkbox-item input[type="checkbox"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    /* Pour que :focus-visible sur l'input éclaire le label */
  }

  .checkbox-item label {
    display: block;
    padding: 0.75rem 1rem;
    border: 1px solid var(--gray-line);
    border-radius: 100px;
    background: var(--white);
    font-size: 0.9rem;
    color: var(--ink-soft);
    text-align: center;
    cursor: pointer;
    transition: all 0.25s ease;
    user-select: none;
  }

  .checkbox-item label:hover {
    border-color: var(--rose-pale);
  }

  .checkbox-item input[type="checkbox"]:checked + label {
    background: var(--berry);
    color: var(--cream);
    border-color: var(--berry);
    font-style: italic;
  }

  /* Focus visible accessibilité (clavier) */
  .checkbox-item input[type="checkbox"]:focus-visible + label {
    outline: 2px solid var(--berry);
    outline-offset: 3px;
  }

  /* ============================================================
     BOUTON SUBMIT
     ============================================================ */
  .submit-btn {
    width: 100%;
    padding: 1.2rem 2rem;
    border: none;
    background: var(--berry);
    color: var(--cream);
    font-family: "Cardo", serif;
    font-size: 1rem;
    border-radius: 100px;
    cursor: pointer;
    transition: all 0.3s ease;
    letter-spacing: 0.02em;
    margin-top: 2rem;
    min-height: 52px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .submit-btn:hover:not(:disabled) {
    background: var(--berry-deep);
    transform: translateY(-2px);
    box-shadow: 0 16px 36px rgba(74, 31, 48, 0.22);
  }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none !important;
    box-shadow: none !important;
  }

  /* Loading state */
  .btn-loading {
    display: none;
    align-items: center;
    gap: 0.6rem;
  }

  .submit-btn.loading .btn-label {
    display: none;
  }

  .submit-btn.loading .btn-loading {
    display: inline-flex;
  }

  .spinner {
    width: 16px;
    height: 16px;
    border: 2px solid rgba(236, 226, 208, 0.3);
    border-top-color: var(--cream);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Message global (erreur réseau / serveur) */
  .form-message {
    margin-top: 1.2rem;
    font-size: 0.95rem;
    line-height: 1.5;
    min-height: 0;
    text-align: center;
    transition: color 0.3s ease;
  }

  .form-message.error {
    color: #b91c1c;
  }

  .form-note {
    font-size: 0.82rem;
    margin-top: 1.5rem;
    color: var(--gray-mid);
    font-style: italic;
    text-align: center;
  }

  /* ============================================================
     WIDGET DE SUCCÈS
     ============================================================ */
  .success-card {
    background: var(--white);
    border-radius: 4px;
    padding: 3.5rem 3rem;
    box-shadow: 0 30px 80px rgba(74, 31, 48, 0.08);
    text-align: center;
    position: relative;
    overflow: hidden;
    animation: success-card-enter 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .success-card[hidden] {
    display: none;
  }

  .success-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 3px;
    background: var(--gold);
  }

  @keyframes success-card-enter {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .success-icon {
    color: var(--berry);
    margin: 0 auto 2rem;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .success-icon-circle {
    stroke-dasharray: 164;
    stroke-dashoffset: 164;
    animation: draw-circle 0.8s ease-out 0.2s forwards;
    transform-origin: center;
  }

  .success-icon-check {
    stroke-dasharray: 50;
    stroke-dashoffset: 50;
    animation: draw-check 0.5s ease-out 0.9s forwards;
  }

  @keyframes draw-circle {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes draw-check {
    to {
      stroke-dashoffset: 0;
    }
  }

  .success-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--berry);
    margin-bottom: 1rem;
    font-weight: 500;
    animation: fade-up 0.6s ease-out 1.2s both;
  }

  .success-title {
    font-family: "Cormorant Infant", serif;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--ink);
    margin: 0 0 1.5rem;
    text-wrap: balance;
    animation: fade-up 0.6s ease-out 1.3s both;
  }

  .success-title em {
    font-style: italic;
    color: var(--berry);
  }

  .success-intro {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 auto;
    max-width: 500px;
    animation: fade-up 0.6s ease-out 1.4s both;
  }

  .success-email {
    color: var(--berry);
    font-weight: 500;
    word-break: break-word;
    display: inline-block;
    margin-top: 0.3rem;
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .success-divider {
    margin: 2.5rem auto;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fade-up 0.6s ease-out 1.5s both;
  }

  .success-divider span {
    display: block;
    width: 40px;
    height: 1px;
    background: var(--gold);
    position: relative;
  }

  .success-divider span::before,
  .success-divider span::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 4px;
    height: 4px;
    background: var(--gold);
    border-radius: 50%;
    transform: translateY(-50%);
  }

  .success-divider span::before {
    left: -10px;
  }
  .success-divider span::after {
    right: -10px;
  }

  .success-steps {
    text-align: left;
    max-width: 480px;
    margin: 0 auto;
    animation: fade-up 0.6s ease-out 1.6s both;
  }

  .success-steps-title {
    font-size: 0.75rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .success-steps ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .success-steps li {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 1.1rem;
    align-items: baseline;
    padding: 1.1rem 0;
    border-top: 1px solid var(--gray-line);
  }

  .success-steps li:last-child {
    border-bottom: 1px solid var(--gray-line);
  }

  .step-num {
    font-family: "Cormorant Infant", serif;
    font-size: 1.2rem;
    font-style: italic;
    color: var(--berry);
    line-height: 1;
    font-weight: 500;
  }

  .step-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .step-label {
    font-family: "Cormorant Infant", serif;
    font-size: 1.05rem;
    font-style: italic;
    color: var(--ink);
    font-weight: 500;
    line-height: 1.3;
  }

  .step-text {
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--ink-soft);
  }

  /* ----- Signature Adner ----- */
  .success-signature {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--gray-line);
    animation: fade-up 0.6s ease-out 1.65s both;
  }

  .success-signature .sig-name {
    font-family: "Caveat", cursive;
    font-size: 2.2rem;
    color: var(--berry);
    line-height: 1;
    margin-bottom: 0.4rem;
  }

  .success-signature .sig-role {
    font-size: 0.85rem;
    color: var(--ink-soft);
    font-style: italic;
  }

  .success-back {
    display: inline-block;
    margin-top: 2.5rem;
    color: var(--berry);
    text-decoration: none;
    font-size: 0.95rem;
    font-style: italic;
    border-bottom: 1px solid var(--berry);
    padding: 0.3rem 0;
    transition: padding-right 0.3s ease;
    animation: fade-up 0.6s ease-out 1.7s both;
  }

  .success-back:hover {
    padding-right: 0.8rem;
  }

  /* Respect prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .success-card,
    .success-eyebrow,
    .success-title,
    .success-intro,
    .success-divider,
    .success-steps,
    .success-signature,
    .success-back {
      animation: none !important;
    }
    .success-icon-circle,
    .success-icon-check {
      stroke-dashoffset: 0 !important;
      animation: none !important;
    }
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 968px) {
    .final-cta {
      padding: 6rem 1.5rem 5rem;
    }
  }

  @media (max-width: 768px) {
    .form-row {
      grid-template-columns: 1fr;
      gap: 0;
      margin-bottom: 0;
    }

    .form-row .form-group:first-child {
      margin-bottom: 1.2rem;
    }

    .checkbox-grid {
      grid-template-columns: 1fr 1fr;
    }

    .success-card {
      padding: 2.5rem 1.5rem;
    }

    .success-steps li {
      grid-template-columns: 28px 1fr;
      gap: 0.9rem;
      padding: 0.9rem 0;
    }
  }

  @media (max-width: 420px) {
    .checkbox-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  /**
   * ───────────────────────────────────────────────────────────────
   *  URL du backend qui reçoit la soumission.
   *  Payload envoyé en JSON :
   *  {
   *    firstname: string,
   *    lastname:  string,
   *    email:     string,
   *    canton:    string | "",
   *    symptoms:  string[],
   *    lang:      "fr" | "en"
   *  }
   * ───────────────────────────────────────────────────────────────
   */
  const ENDPOINT = "https://api.sylvanacare.ch/api/novaclinic-waitlist";

  const initial = document.getElementById("ctaInitial");
  const form = document.getElementById("contactForm") as HTMLFormElement | null;
  const submitBtn = document.getElementById(
    "submitBtn",
  ) as HTMLButtonElement | null;

  const firstnameInput = document.getElementById(
    "firstname",
  ) as HTMLInputElement | null;
  const lastnameInput = document.getElementById(
    "lastname",
  ) as HTMLInputElement | null;
  const emailInput = document.getElementById(
    "email",
  ) as HTMLInputElement | null;
  const cantonSelect = document.getElementById(
    "canton",
  ) as HTMLSelectElement | null;

  const formMessage = document.getElementById(
    "formMessage",
  ) as HTMLElement | null;
  const successCard = document.getElementById("successCard");
  const successEmail = document.getElementById("successEmail");
  const successTitlePrefix = document.getElementById("successTitlePrefix");

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  if (
    form &&
    submitBtn &&
    firstnameInput &&
    lastnameInput &&
    emailInput &&
    cantonSelect &&
    formMessage &&
    successCard &&
    successEmail &&
    successTitlePrefix
  ) {
    const lang = (form.dataset.lang || "fr") as "fr" | "en";
    const errorMsg = formMessage.dataset.error || "Erreur.";

    // Récupère le template du titre de succès depuis l'i18n via une astuce :
    // on lit le pattern dans un attribut data ajouté au render-time côté Astro.
    // Plus simple : on hardcode les deux versions ici puisque c'est juste du remplacement de prénom.
    const titlePrefixTemplate =
      lang === "fr"
        ? "Merci {firstname}, votre place est "
        : "Thank you {firstname}, your place is ";

    // ───── Helpers de validation ─────
    const setFieldError = (
      input: HTMLElement,
      errorId: string,
      hasError: boolean,
    ) => {
      input.setAttribute("aria-invalid", hasError ? "true" : "false");
      const errEl = document.getElementById(errorId);
      if (errEl) {
        if (hasError) errEl.classList.add("visible");
        else errEl.classList.remove("visible");
      }
    };

    const validateField = (
      input: HTMLInputElement,
      errorId: string,
      validator: (val: string) => boolean,
    ): boolean => {
      const isValid = validator(input.value.trim());
      setFieldError(input, errorId, !isValid);
      return isValid;
    };

    // Validation à la perte de focus (UX : feedback immédiat sans être agressif)
    firstnameInput.addEventListener("blur", () => {
      if (firstnameInput.value.trim()) {
        validateField(firstnameInput, "firstnameError", (v) => v.length > 0);
      }
    });
    lastnameInput.addEventListener("blur", () => {
      if (lastnameInput.value.trim()) {
        validateField(lastnameInput, "lastnameError", (v) => v.length > 0);
      }
    });
    emailInput.addEventListener("blur", () => {
      if (emailInput.value.trim()) {
        validateField(emailInput, "emailError", (v) => EMAIL_RE.test(v));
      }
    });

    // Effacer l'erreur quand l'utilisateur retape
    [
      { input: firstnameInput, id: "firstnameError" },
      { input: lastnameInput, id: "lastnameError" },
      { input: emailInput, id: "emailError" },
    ].forEach(({ input, id }) => {
      input.addEventListener("input", () => {
        if (input.getAttribute("aria-invalid") === "true") {
          setFieldError(input, id, false);
        }
      });
    });

    const setMessage = (text: string, type: "error" | "" = "") => {
      formMessage.textContent = text;
      formMessage.className = "form-message" + (type ? ` ${type}` : "");
    };

    const setLoading = (loading: boolean) => {
      if (loading) {
        submitBtn.classList.add("loading");
        submitBtn.disabled = true;
      } else {
        submitBtn.classList.remove("loading");
        submitBtn.disabled = false;
      }
    };

    const showSuccess = (firstname: string, email: string) => {
      // Personnaliser le titre avec le prénom
      const prefix = titlePrefixTemplate.replace("{firstname}", firstname);
      successTitlePrefix.textContent = prefix;
      successEmail.textContent = email;

      // Masquer le formulaire, afficher la carte
      initial?.classList.add("hidden");
      successCard.hidden = false;

      // Scroller doucement vers le widget
      setTimeout(() => {
        successCard.scrollIntoView({ behavior: "smooth", block: "center" });
      }, 100);
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const firstname = firstnameInput.value.trim();
      const lastname = lastnameInput.value.trim();
      const email = emailInput.value.trim();
      const canton = cantonSelect.value;
      const symptoms = Array.from(
        form.querySelectorAll<HTMLInputElement>(
          'input[name="symptoms"]:checked',
        ),
      ).map((cb) => cb.value);

      // Validation des champs requis
      const okFirstname = validateField(
        firstnameInput,
        "firstnameError",
        (v) => v.length > 0,
      );
      const okLastname = validateField(
        lastnameInput,
        "lastnameError",
        (v) => v.length > 0,
      );
      const okEmail = validateField(emailInput, "emailError", (v) =>
        EMAIL_RE.test(v),
      );

      if (!okFirstname || !okLastname || !okEmail) {
        // Focus sur le premier champ en erreur (accessibilité)
        const firstError = form.querySelector<HTMLInputElement>(
          '[aria-invalid="true"]',
        );
        firstError?.focus();
        return;
      }

      setMessage("", "");
      setLoading(true);

      try {
        const response = await fetch(ENDPOINT, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            firstname,
            lastname,
            email,
            canton,
            symptoms,
            lang,
          }),
        });

        if (response.ok) {
          showSuccess(firstname, email);
        } else {
          throw new Error(`HTTP ${response.status}`);
        }
      } catch (err) {
        console.error("Contact form error:", err);
        setMessage(errorMsg, "error");
        setLoading(false);
      }
    });
  }
</script>
