---
/**
 * Section Lieu — visualisation du centre + liste expériences + care manager
 *
 * CORRECTIONS HTML ORIGINAL :
 * - Le bloc care-manager passe trop souvent en grille 80px+1fr trop tassée sur tablette
 *   → on assouplit avec auto-fit-friendly et meilleur fallback mobile
 */

import { getLangFromUrl, type Lang } from '../i18n/config';
import { t } from '../i18n/ui';

const lang: Lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
---

<section class="lieu" id="lieu" aria-labelledby="lieu-title">
  <div class="lieu-grid">
    <div class="lieu-visual reveal" role="img" aria-label={i18n.lieu.centerName.join(' ')}>
      <div class="lieu-overlay">
        <div class="label">{i18n.lieu.label}</div>
        <h4>{i18n.lieu.centerName.map((line, idx) => (
          <>
            {line}{idx < i18n.lieu.centerName.length - 1 && <br />}
          </>
        ))}</h4>
        <p class="address">
          {i18n.lieu.address1}<br />
          {i18n.lieu.address2}
        </p>
      </div>
    </div>

    <div class="lieu-content reveal">
      <h2 id="lieu-title">
        {i18n.lieu.titleLine1}<em>{i18n.lieu.titleEm1}</em><br />
        {i18n.lieu.titleLine2}
      </h2>
      <p>{i18n.lieu.text}</p>

      <ul class="lieu-experiences">
        {i18n.lieu.experiences.map((exp) => (
          <li>
            <span class="num">{exp.num}</span>
            <span class="text" set:html={exp.text} />
          </li>
        ))}
      </ul>

      <div class="care-manager-block">
        <div class="cm-portrait" aria-hidden="true">
          <div class="cm-initial">{i18n.lieu.careManager.initial}</div>
        </div>
        <div class="cm-content">
          <div class="cm-eyebrow">{i18n.lieu.careManager.eyebrow}</div>
          <h4>{i18n.lieu.careManager.name}</h4>
          <p set:html={i18n.lieu.careManager.text} />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .lieu {
    padding: 9rem 3.5rem;
    background: var(--cream-light);
    position: relative;
    z-index: 1;
  }

  .lieu-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 5rem;
    align-items: center;
  }

  /* Visual : carré dégradé avec lettre M géante */
  .lieu-visual {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 2px;
    background: linear-gradient(135deg, var(--rose) 0%, var(--berry) 100%);
    min-height: 400px;
  }

  .lieu-visual::before {
    content: 'M';
    position: absolute;
    font-family: 'Cormorant Infant', serif;
    font-size: 38rem;
    font-style: italic;
    color: rgba(236, 226, 208, 0.1);
    line-height: 0.7;
    bottom: -5rem;
    right: -5rem;
    font-weight: 500;
    pointer-events: none;
  }

  .lieu-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 3rem;
    color: var(--cream);
    z-index: 2;
  }

  .lieu-overlay .label {
    font-size: 0.78rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .lieu-overlay h4 {
    font-family: 'Cormorant Infant', serif;
    font-size: 2.4rem;
    font-style: italic;
    line-height: 1.05;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .lieu-overlay .address {
    font-size: 0.95rem;
    color: var(--rose-pale);
    line-height: 1.5;
  }

  /* Content droit */
  .lieu-content h2 {
    font-family: 'Cormorant Infant', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.15;
    margin-bottom: 2rem;
    color: var(--ink);
    text-wrap: balance;
  }

  .lieu-content h2 em {
    font-style: italic;
    color: var(--berry);
  }

  .lieu-content > p {
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--ink-soft);
    margin-bottom: 1.5rem;
  }

  .lieu-experiences {
    margin-top: 3rem;
    list-style: none;
    padding: 0;
  }

  .lieu-experiences li {
    padding: 1.4rem 0;
    border-top: 1px solid var(--gray-line);
    display: grid;
    grid-template-columns: 50px 1fr;
    gap: 1.5rem;
    align-items: baseline;
  }

  .lieu-experiences li:last-child {
    border-bottom: 1px solid var(--gray-line);
  }

  .lieu-experiences .num {
    font-family: 'Cormorant Infant', serif;
    font-style: italic;
    color: var(--berry);
    font-size: 1.3rem;
    font-weight: 500;
  }

  .lieu-experiences .text {
    font-size: 1.05rem;
    color: var(--ink);
    line-height: 1.6;
  }

  .lieu-experiences .text :global(em) {
    font-style: italic;
    color: var(--berry);
  }

  /* Bloc Care Manager */
  .care-manager-block {
    margin-top: 3rem;
    padding: 2rem;
    background: var(--white);
    border-radius: 2px;
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1.5rem;
    align-items: center;
    border-left: 3px solid var(--berry);
  }

  .cm-portrait {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--rose) 0%, var(--berry) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cm-initial {
    font-family: 'Cormorant Infant', serif;
    font-size: 2.5rem;
    font-style: italic;
    color: var(--cream);
    line-height: 1;
    font-weight: 500;
  }

  .cm-content .cm-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--berry);
    font-weight: 500;
    margin-bottom: 0.4rem;
  }

  .cm-content h4 {
    font-family: 'Cormorant Infant', serif;
    font-size: 1.5rem;
    font-style: italic;
    color: var(--ink);
    margin-bottom: 0.7rem;
    font-weight: 500;
    line-height: 1.1;
  }

  .cm-content p {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--ink-soft);
    margin: 0;
  }

  .cm-content p :global(em) {
    font-style: italic;
    color: var(--berry);
  }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 968px) {
    .lieu { padding: 5rem 1.5rem; }
    .lieu-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
      padding: 0;
    }
    .lieu-visual {
      min-height: 350px;
      max-height: 500px;
      aspect-ratio: 16 / 12;
    }
    .lieu-visual::before {
      font-size: 24rem;
    }
    .lieu-overlay {
      padding: 2rem;
    }
    .care-manager-block {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 1rem;
    }
    .cm-portrait {
      margin: 0 auto;
    }
  }
</style>
