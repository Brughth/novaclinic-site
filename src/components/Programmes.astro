---
/**
 * Section Programmes — discovery card + 3 cartes tarifaires (Featured au centre)
 *
 * CORRECTIONS HTML ORIGINAL :
 * - Sur tablette la carte featured (scale 1.05) sortait du grid : on désactive le scale
 *   et on le réactive seulement en desktop
 * - L'ordre des cartes en mobile : on remonte la featured en premier (visuel commercial)
 */

import { getLangFromUrl, type Lang } from '../i18n/config';
import { t } from '../i18n/ui';

const lang: Lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
---

<section class="programmes" id="programmes" aria-labelledby="programmes-title">
  <div class="prog-header reveal">
    <div class="section-eyebrow"><span>{i18n.programmes.eyebrow}</span></div>
    <h2 id="programmes-title" class="section-title">
      {i18n.programmes.titleLine1}<br /><em>{i18n.programmes.titleEm}</em>
    </h2>
    <p class="section-subtitle">{i18n.programmes.subtitle}</p>
  </div>

  <div class="discovery-card reveal">
    <span class="ribbon">{i18n.programmes.discovery.ribbon}</span>
    <h4>
      {i18n.programmes.discovery.titleLine1}<em>{i18n.programmes.discovery.titleEm}</em>
    </h4>
    <p>{i18n.programmes.discovery.text}</p>
    <div class="discovery-options">
      {i18n.programmes.discovery.options.map((opt) => (
        <div class="discovery-option">
          <div class="opt-label">{opt.label}</div>
          <h5>{opt.title}</h5>
          <div class="price-line">
            {opt.priceLinePart1}<strong>{opt.priceLineStrong}</strong>{opt.priceLinePart2}
          </div>
          <p class="opt-text">{opt.text}</p>
          <a href="#contact">{opt.cta}</a>
        </div>
      ))}
    </div>
  </div>

  <p class="prog-intro reveal">{i18n.programmes.intro}</p>

  <div class="prog-grid">
    {i18n.programmes.cards.map((card, idx) => (
      <article
        class={`prog-card reveal ${card.featured ? 'featured' : ''}`}
        style={`transition-delay: ${idx * 100}ms`}
      >
        <div class="prog-tier">{card.tier}</div>
        <h3 class="prog-name">{card.name}</h3>
        <div class="prog-price">
          <span class="price">{card.price}</span>
          <span class="month">{card.month}</span>
        </div>
        <p class="prog-min">{card.engagement}</p>
        <ul class="prog-features">
          {card.features.map((f) => <li>{f}</li>)}
        </ul>
        <a href="#contact" class="prog-cta">{card.cta}</a>
      </article>
    ))}
  </div>
</section>

<style>
  .programmes {
    padding: 9rem 3.5rem;
    background: var(--cream-paper);
    position: relative;
    z-index: 1;
  }

  .programmes :global(.section-eyebrow span) {
    background: var(--cream-paper);
  }

  .prog-header {
    max-width: 850px;
    margin: 0 auto 5rem;
    text-align: center;
  }

  /* ========== Discovery card ========== */
  .discovery-card {
    max-width: 720px;
    margin: 0 auto 4rem;
    padding: 3rem;
    background: var(--white);
    border: 1px dashed var(--rose-pale);
    border-radius: 2px;
    text-align: center;
    position: relative;
  }

  .discovery-card .ribbon {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--gold);
    color: var(--berry-deep);
    padding: 0.4rem 1.5rem;
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    font-weight: 500;
    white-space: nowrap;
  }

  .discovery-card h4 {
    font-family: 'Cormorant Infant', serif;
    font-size: 2rem;
    font-style: italic;
    color: var(--ink);
    margin-bottom: 1rem;
    line-height: 1.1;
    margin-top: 0.5rem;
    font-weight: 500;
  }

  .discovery-card h4 em {
    color: var(--berry);
  }

  .discovery-card > p {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--ink-soft);
    margin-bottom: 1.5rem;
  }

  .discovery-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2rem;
    text-align: left;
  }

  .discovery-option {
    padding: 1.5rem;
    background: var(--cream-light);
    border-radius: 2px;
  }

  .discovery-option .opt-label {
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--berry);
    margin-bottom: 0.6rem;
    font-weight: 500;
  }

  .discovery-option h5 {
    font-family: 'Cormorant Infant', serif;
    font-size: 1.3rem;
    font-style: italic;
    color: var(--ink);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .discovery-option .price-line {
    font-size: 0.95rem;
    color: var(--ink-soft);
    margin-bottom: 1rem;
    font-style: italic;
  }

  .discovery-option .price-line strong {
    color: var(--berry);
    font-weight: 500;
    font-style: normal;
  }

  .discovery-option .opt-text {
    font-size: 0.85rem;
    line-height: 1.5;
    margin: 0.8rem 0;
    color: var(--ink-soft);
  }

  .discovery-option a {
    color: var(--berry);
    text-decoration: none;
    font-size: 0.9rem;
    border-bottom: 1px solid var(--berry);
    padding-bottom: 0.2rem;
    font-style: italic;
    transition: padding-right 0.3s ease;
  }

  .discovery-option a:hover { padding-right: 1rem; }

  .prog-intro {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3rem;
    font-size: 1.1rem;
    color: var(--ink-soft);
    font-style: italic;
    line-height: 1.7;
  }

  /* ========== Grid 3 cartes ========== */
  .prog-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.85fr 1fr 0.85fr;
    gap: 1.5rem;
    align-items: stretch;
  }

  .prog-card {
    padding: 3rem 2.2rem;
    background: var(--cream-light);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    position: relative;
    border-radius: 2px;
    display: flex;
    flex-direction: column;
  }

  .prog-card.featured {
    background: var(--berry);
    color: var(--cream);
    transform: scale(1.05);
    box-shadow: 0 30px 70px rgba(74, 31, 48, 0.18);
    z-index: 2;
  }

  /* Réveal initial — on étend le transform pour ne pas annuler le scale */
  .prog-card.featured.reveal {
    transform: scale(1.05) translateY(30px);
  }
  .prog-card.featured.reveal.visible {
    transform: scale(1.05) translateY(0);
  }

  .prog-card:not(.featured):hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 32px rgba(74, 31, 48, 0.08);
  }

  .prog-tier {
    font-size: 0.78rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--berry);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .prog-card.featured .prog-tier {
    color: var(--gold);
  }

  .prog-name {
    font-family: 'Cormorant Infant', serif;
    font-size: 2.2rem;
    font-style: italic;
    font-weight: 500;
    margin-bottom: 1.5rem;
    line-height: 1;
  }

  .prog-price {
    font-family: 'Cormorant Infant', serif;
    margin-bottom: 0.4rem;
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }

  .prog-price .price {
    font-size: 3.5rem;
    font-weight: 500;
    line-height: 1;
  }

  .prog-price .month {
    font-size: 0.95rem;
    font-style: italic;
    opacity: 0.7;
  }

  .prog-min {
    font-size: 0.85rem;
    color: var(--gray-mid);
    margin-bottom: 2rem;
    font-style: italic;
  }

  .prog-card.featured .prog-min {
    color: var(--rose-pale);
  }

  .prog-features {
    list-style: none;
    margin-bottom: 2rem;
    flex: 1;
    padding: 0;
  }

  .prog-features li {
    padding: 0.7rem 0;
    font-size: 0.95rem;
    color: var(--ink-soft);
    border-bottom: 1px solid var(--gray-line);
    line-height: 1.5;
  }

  .prog-features li:first-child {
    font-style: italic;
    color: var(--berry);
  }

  .prog-card.featured .prog-features li {
    color: var(--cream);
    border-color: rgba(236, 226, 208, 0.15);
  }

  .prog-card.featured .prog-features li:first-child {
    color: var(--gold);
  }

  .prog-features li:last-child { border-bottom: none; }

  .prog-cta {
    display: block;
    text-align: center;
    padding: 1rem;
    background: transparent;
    color: var(--berry);
    border: 1px solid var(--berry);
    text-decoration: none;
    font-size: 0.95rem;
    border-radius: 100px;
    transition: all 0.3s ease;
    font-style: italic;
  }

  .prog-cta:hover {
    background: var(--berry);
    color: var(--cream);
    font-style: normal;
  }

  .prog-card.featured .prog-cta {
    background: var(--gold);
    color: var(--berry-deep);
    border-color: var(--gold);
    font-weight: 500;
    font-style: normal;
  }

  .prog-card.featured .prog-cta:hover {
    background: var(--cream);
    border-color: var(--cream);
  }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 1100px) {
    .prog-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
    /* Désactive le scale qui débordait du grid sur tablette */
    .prog-card.featured {
      transform: none;
    }
    .prog-card.featured.reveal {
      transform: translateY(30px);
    }
    .prog-card.featured.reveal.visible {
      transform: translateY(0);
    }
  }

  @media (max-width: 968px) {
    .programmes { padding: 5rem 1.5rem; }
    .discovery-card { padding: 2.5rem 1.5rem; }
    .discovery-options { grid-template-columns: 1fr; }
    .prog-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    /* La featured passe en premier sur mobile (commercial) */
    .prog-card.featured {
      order: -1;
    }
  }
</style>
