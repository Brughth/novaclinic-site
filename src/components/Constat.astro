---
/**
 * Section Constat — texte éditorial avec lettrine
 */

import { getLangFromUrl, type Lang } from '../i18n/config';
import { t } from '../i18n/ui';

const lang: Lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
---

<section class="constat">
  <div class="constat-container reveal">
    <div class="section-eyebrow"><span>{i18n.constat.eyebrow}</span></div>
    <div class="constat-text">
      {i18n.constat.paragraphs.map((p) => (
        <p>
          {p.text}
          {'em' in p && p.em && <em>{p.em}</em>}
          {'strong' in p && p.strong && <strong>{p.strong}</strong>}
          {'suffix' in p && p.suffix}
        </p>
      ))}
    </div>
    <div class="section-cta">
      <a href="#parcours">{i18n.constat.cta}</a>
    </div>
  </div>
</section>

<style>
  .constat {
    padding: 9rem 3.5rem;
    position: relative;
    z-index: 1;
    background: var(--white);
  }

  .constat-container {
    max-width: 920px;
    margin: 0 auto;
  }

  /* Background-color du label éclipsant la ligne — la section a son propre bg */
  .constat :global(.section-eyebrow span) {
    background: var(--white);
  }

  .constat-text {
    font-family: 'Cormorant Infant', serif;
    font-size: clamp(1.4rem, 2.4vw, 1.85rem);
    line-height: 1.55;
    color: var(--ink);
    font-weight: 400;
  }

  .constat-text :global(p) {
    margin-bottom: 1.8rem;
  }

  /* Lettrine sur le premier paragraphe */
  .constat-text :global(p:first-child::first-letter) {
    font-size: 4.5rem;
    float: left;
    line-height: 0.9;
    margin: 0.15rem 0.7rem 0 0;
    color: var(--berry);
    font-weight: 500;
    font-style: italic;
  }

  .constat-text :global(em) {
    font-style: italic;
    color: var(--berry);
  }

  .constat-text :global(strong) {
    font-weight: 500;
    color: var(--berry);
    font-style: normal;
  }

  @media (max-width: 968px) {
    .constat { padding: 5rem 1.5rem; }
    .constat-text :global(p:first-child::first-letter) {
      font-size: 3.5rem;
    }
  }
</style>
