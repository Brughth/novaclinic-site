---
/**
 * Section Pourquoi — fond berry intense, déclaration personnelle
 *
 * CORRECTION HTML ORIGINAL :
 * - Sur tablette/mobile, les cercles décoratifs débordent : on les contraint avec overflow:hidden
 */

import { getLangFromUrl, type Lang } from '../i18n/config';
import { t } from '../i18n/ui';

const lang: Lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
---

<section class="pourquoi" id="pourquoi" aria-labelledby="pourquoi-title">
  <div class="pourquoi-container reveal">
    <div class="section-eyebrow"><span id="pourquoi-title">{i18n.pourquoi.eyebrow}</span></div>

    <div class="pourquoi-text">
      {i18n.pourquoi.paragraphs.map((p) => <p set:html={p} />)}
      <p class="pourquoi-final">{i18n.pourquoi.final}</p>
    </div>

    <div class="pourquoi-signature">
      <div>
        <div class="name">{i18n.pourquoi.signature.name}</div>
        <div class="role">{i18n.pourquoi.signature.role}</div>
      </div>
    </div>

    <div class="pourquoi-cta">
      <a href="#piliers">{i18n.pourquoi.cta}</a>
    </div>
  </div>
</section>

<style>
  .pourquoi {
    padding: 9rem 3.5rem;
    background: var(--berry);
    color: var(--cream);
    position: relative;
    overflow: hidden;
    z-index: 1;
  }

  /* Cercles décoratifs */
  .pourquoi::before {
    content: '';
    position: absolute;
    top: -200px; right: -200px;
    width: 600px; height: 600px;
    border: 1px solid rgba(236, 226, 208, 0.05);
    border-radius: 50%;
    pointer-events: none;
  }

  .pourquoi::after {
    content: '';
    position: absolute;
    bottom: -300px; left: -300px;
    width: 800px; height: 800px;
    border: 1px solid rgba(236, 226, 208, 0.04);
    border-radius: 50%;
    pointer-events: none;
  }

  .pourquoi-container {
    max-width: 820px;
    margin: 0 auto;
    text-align: left;
    position: relative;
    z-index: 2;
  }

  /* Override section-eyebrow pour fond berry */
  .pourquoi :global(.section-eyebrow) {
    text-align: left;
    margin-bottom: 3rem;
  }

  .pourquoi :global(.section-eyebrow::before) {
    display: none;
  }

  .pourquoi :global(.section-eyebrow span) {
    color: var(--gold);
    background: transparent;
    padding: 0;
    border-bottom: 1px solid var(--gold);
    padding-bottom: 0.5rem;
  }

  .pourquoi-text {
    font-family: 'Cormorant Infant', serif;
    font-size: clamp(1.6rem, 2.8vw, 2.2rem);
    line-height: 1.45;
    color: var(--cream);
    font-weight: 400;
    font-style: italic;
  }

  .pourquoi-text :global(p) {
    margin-bottom: 1.5rem;
  }

  .pourquoi-text :global(strong) {
    color: var(--gold);
    font-weight: 500;
    font-style: normal;
  }

  .pourquoi-final {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(201, 169, 97, 0.3);
    font-family: 'Cardo', serif !important;
    font-size: 1.05rem !important;
    font-style: italic !important;
    color: var(--rose-pale) !important;
    letter-spacing: 0.05em;
  }

  .pourquoi-signature {
    margin-top: 3rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .pourquoi-signature .name {
    font-family: 'Caveat', cursive;
    font-size: 2.2rem;
    color: var(--gold);
    line-height: 1;
  }

  .pourquoi-signature .role {
    font-size: 0.95rem;
    color: var(--rose-pale);
    font-style: italic;
  }

  .pourquoi-cta {
    margin-top: 4rem;
    text-align: center;
  }

  .pourquoi-cta a {
    color: var(--gold);
    text-decoration: none;
    font-size: 1.05rem;
    font-style: italic;
    border-bottom: 1px solid var(--gold);
    padding: 0.4rem 0;
    transition: padding-right 0.3s ease, color 0.3s ease;
  }

  .pourquoi-cta a:hover {
    padding-right: 1.5rem;
    color: var(--cream);
  }

  @media (max-width: 968px) {
    .pourquoi { padding: 5rem 1.5rem; }
    .pourquoi::before {
      width: 400px; height: 400px;
      top: -150px; right: -150px;
    }
    .pourquoi::after {
      width: 500px; height: 500px;
      bottom: -200px; left: -200px;
    }
  }
</style>
