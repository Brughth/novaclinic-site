---
/**
 * Section Comparatif — tableau cabinet classique vs Novacare
 *
 * CORRECTIONS HTML ORIGINAL :
 * - Ajout d'un indice visuel "Faites défiler →" sur mobile pour signaler le scroll horizontal
 * - Gradient de fade sur le côté droit pour signaler la possibilité de scroller
 */

import { getLangFromUrl, type Lang } from "../i18n/config";
import { t } from "../i18n/ui";

const lang: Lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
---

<section class="comparatif" aria-labelledby="comparatif-title">
  <div class="comparatif-header reveal">
    <div class="section-eyebrow"><span>{i18n.comparatif.eyebrow}</span></div>
    <h2 id="comparatif-title" class="section-title">
      {i18n.comparatif.titleLine1}<em>{i18n.comparatif.titleEm}</em>{
        i18n.comparatif.titleLine2.replace(/<br ?\/?>/, ",")
      }
    </h2>
    <p class="section-subtitle">{i18n.comparatif.subtitle}</p>
  </div>

  <div class="comparatif-scroll-hint" id="scrollHint" aria-hidden="true">
    {i18n.comparatif.swipeHint}
  </div>

  <div class="comparatif-table-wrap reveal" id="tableWrap">
    <table class="comparatif-table">
      <thead>
        <tr>
          <th scope="col"
            ><span class="visually-hidden">{i18n.comparatif.eyebrow}</span></th
          >
          <th scope="col">{i18n.comparatif.headers.classic}</th>
          <th scope="col" class="novacare-col"
            >{i18n.comparatif.headers.novacare}</th
          >
        </tr>
      </thead>
      <tbody>
        {
          i18n.comparatif.rows.map((row) => (
            <tr>
              <th scope="row">{row.label}</th>
              <td class="center">{row.classic}</td>
              <td class="novacare-cell">
                <em>{row.novacare}</em>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <div class="comparatif-cta reveal">
    <p class="bottom-note">{i18n.comparatif.bottomNote}</p>
    <a href="#lieu" class="btn btn-link">{i18n.comparatif.bottomCta}</a>
  </div>
</section>

<style>
  .comparatif {
    padding: 9rem 3.5rem;
    background: var(--cream);
    position: relative;
    z-index: 1;
  }

  .comparatif :global(.section-eyebrow span) {
    background: var(--cream);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .comparatif-header {
    max-width: 800px;
    margin: 0 auto 5rem;
    text-align: center;
  }

  /* Indice de scroll mobile */
  .comparatif-scroll-hint {
    display: none;
    max-width: 1000px;
    margin: 0 auto 0.8rem;
    text-align: right;
    font-size: 0.78rem;
    color: var(--berry);
    font-style: italic;
    letter-spacing: 0.08em;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .comparatif-table-wrap {
    max-width: 1000px;
    margin: 0 auto;
    overflow-x: auto;
    border-radius: 2px;
    box-shadow: 0 20px 50px rgba(74, 31, 48, 0.06);
    position: relative;
    -webkit-overflow-scrolling: touch;
  }

  .comparatif-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--white);
    min-width: 580px;
  }

  .comparatif-table thead tr {
    background: var(--cream-light);
  }

  .comparatif-table th {
    padding: 1.5rem;
    text-align: left;
    font-family: "Cardo", serif;
    font-weight: 400;
    font-size: 0.85rem;
    color: var(--ink-soft);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--gray-line);
  }

  .comparatif-table th.novacare-col {
    background: var(--berry);
    color: var(--gold);
    font-weight: 500;
    text-align: center;
  }

  .comparatif-table th:first-child {
    background: var(--white);
    font-style: italic;
    color: var(--berry);
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.95rem;
  }

  .comparatif-table td {
    padding: 1.3rem 1.5rem;
    border-bottom: 1px solid var(--gray-line);
    font-size: 0.95rem;
    color: var(--ink-soft);
    vertical-align: middle;
  }

  .comparatif-table tbody th {
    /* Re-style des "row headers" pour qu'ils se comportent comme la première colonne */
    padding: 1.3rem 1.5rem;
    border-bottom: 1px solid var(--gray-line);
    font-family: "Cormorant Infant", serif;
    font-size: 1.15rem;
    font-style: italic;
    color: var(--ink);
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
    text-align: left;
    background: transparent;
  }

  .comparatif-table tr:last-child td,
  .comparatif-table tr:last-child th {
    border-bottom: none;
  }

  .comparatif-table td.novacare-cell {
    background: var(--cream-paper);
    color: var(--berry);
    font-weight: 500;
    text-align: center;
  }

  .comparatif-table td.novacare-cell em {
    font-style: italic;
    color: var(--berry);
  }

  .comparatif-table td.center {
    text-align: center;
  }

  .comparatif-cta {
    text-align: center;
    margin-top: 4rem;
  }

  .bottom-note {
    font-size: 0.9rem;
    color: var(--ink-soft);
    font-style: italic;
    margin: 0 auto 1.5rem;
    max-width: 600px;
  }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 768px) {
    .comparatif {
      padding: 5rem 1.5rem;
    }
    .comparatif-table th,
    .comparatif-table td,
    .comparatif-table tbody th {
      padding: 0.9rem 0.7rem;
      font-size: 0.85rem;
    }
    .comparatif-table tbody th {
      font-size: 0.95rem;
    }
    .comparatif-scroll-hint {
      display: block;
    }
    /* Gradient de fade signale qu'on peut scroller */
    .comparatif-table-wrap.has-overflow:not(.scrolled-end)::after {
      content: "";
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      width: 24px;
      background: linear-gradient(
        to right,
        transparent,
        rgba(255, 255, 255, 0.6)
      );
      pointer-events: none;
      transition: opacity 0.3s ease;
    }
  }
</style>

<script>
  const wrap = document.getElementById("tableWrap");
  const hint = document.getElementById("scrollHint");

  if (wrap) {
    // Détecter si le tableau déborde réellement (overflow horizontal)
    const checkOverflow = () => {
      if (wrap.scrollWidth > wrap.clientWidth + 2) {
        wrap.classList.add("has-overflow");
      } else {
        wrap.classList.remove("has-overflow");
      }
    };

    // Vérifier au chargement et au resize
    checkOverflow();
    window.addEventListener("resize", checkOverflow, { passive: true });

    // Masquer le hint + le gradient quand on a scrollé jusqu'au bout
    wrap.addEventListener(
      "scroll",
      () => {
        if (hint && wrap.scrollLeft > 20) hint.style.opacity = "0";
        if (wrap.scrollLeft + wrap.clientWidth >= wrap.scrollWidth - 4) {
          wrap.classList.add("scrolled-end");
        } else {
          wrap.classList.remove("scrolled-end");
        }
      },
      { passive: true },
    );
  }
</script>
